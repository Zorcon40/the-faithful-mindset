# Public site URL (used as fallback referrer for Kit)
NEXT_PUBLIC_SITE_URL=https://thefaithfulmindset.com

# Kit (kit.com) — newsletter list + builder; v4 API key from Settings → Advanced
KIT_API_KEY=
# Numeric form ID from your Kit form (enables incentive / double opt-in tied to that form)
KIT_FORM_ID=

# Resend — contact form notifications only
RESEND_API_KEY=
RESEND_FROM_EMAIL=contact@thefaithfulmindset.com
CONTACT_NOTIFY_EMAIL=hello@thefaithfulmindset.com
